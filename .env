# TradeBot Pro - Environment Configuration
# =========================================

# Server Configuration
JWT_SECRET=tradebot_secret_key_2024
PORT=5000
NODE_ENV=development

# Development Settings
FRONTEND_URL=http://localhost:3000
DOMAIN=localhost:3000

# ===== DEPLOYMENT CONFIGURATION =====
# After deploying, fill these in:

# Your custom domain (e.g., tradebotpro.com)
# DOMAIN=your-domain.com

# Frontend URL on Vercel (e.g., https://your-app.vercel.app)  
# FRONTEND_URL=https://your-app.vercel.app

# ===== PRODUCTION DATABASE =====
# MongoDB Atlas connection string (get free at mongodb.com/atlas)
# MONGODB_URI=mongodb+srv://username:password@cluster.xxxx.mongodb.net/tradebot